<Window x:Class="MG_Project.Desktop.Windows.EditEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MG_Project.Desktop.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:EditEmployeeViewModel}"
        mc:Ignorable="d"
        Title="Edycja pracownika" 
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Edytuj dane pracownika" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Width="350">

            <TextBlock Text="Imię:" Margin="0,5,0,2"/>
            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>

            <TextBlock Text="Nazwisko:" Margin="0,10,0,2"/>
            <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>

            <TextBlock Text="Stanowisko:" Margin="0,10,0,2"/>
            <TextBox Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>

            <TextBlock Text="Wynagrodzenie (PLN):" Margin="0,10,0,2"/>
            <TextBox Text="{Binding BaseSalary, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>

            <Label Content="Przypisana Firma:" />
            <ComboBox ItemsSource="{Binding AvailableFirms}" 
            SelectedItem="{Binding SelectedFirm}"
            DisplayMemberPath="Name" 
            Width="200" 
            Height="30"
            Margin="0,0,0,10"/>
            
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Anuluj" 
                    Command="{Binding CancelCommand}" 
                    IsCancel="True"
                    Width="100" Margin="0,0,10,0" Padding="5"/>

            <Button Content="Zapisz zmiany" 
                    Command="{Binding SaveCommand}" 
                    IsDefault="True"
                    Width="100" Padding="5"/>
        </StackPanel>
    </Grid>
</Window>