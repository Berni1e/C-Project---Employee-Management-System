<Window x:Class="MG_Project.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="System Zarządzania (MG Project)" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <TabControl Margin="5">

            <TabItem Header="Pracownicy">
                <Grid x:Name="EmployeesView" Margin="10">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Lista Pracowników" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                            <Button Content="Odśwież" Command="{Binding LoadDataCommand}" Padding="10,5" Margin="0,0,10,0"/>
                            <Button Content="+ Dodaj Pracownika" Command="{Binding AddCommand}" Padding="10,5" Background="#D4EDDA"/>
                        </StackPanel>

                        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" Padding="10" Margin="0,10,0,0" CornerRadius="4">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Wybrany:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedEmployee.LastName}" VerticalAlignment="Center" Margin="0,0,20,0"/>

                                <Button Content="Edytuj" Command="{Binding EditCommand}" Padding="15,5" Margin="0,0,10,0"/>
                                <Button Content="Usuń" 
                                    Command="{Binding DataContext.DeleteCommand, ElementName=EmployeesView}" 
                                    Padding="15,5" 
                                    Background="#F8D7DA"
                                    Margin="5,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>

                            <DataGrid Grid.Column="0" 
                                      ItemsSource="{Binding Employees}" 
                                      SelectedItem="{Binding SelectedEmployee}"
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="1" BorderBrush="#DDD">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Imię" Binding="{Binding FirstName}" Width="*"/>
                                    <DataGridTextColumn Header="Nazwisko" Binding="{Binding LastName}" Width="*"/>
                                    <DataGridTextColumn Header="Stanowisko" Binding="{Binding Position}" Width="150"/>
                                    <DataGridTextColumn Header="Miasto" Binding="{Binding Address.City}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Column="1" Margin="15,0,0,0" DataContext="{Binding SelectedEmployee}">
                                <TextBlock Text="Szczegóły" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <Border BorderBrush="#DDD" BorderThickness="1" Padding="10" Background="White">
                                    <StackPanel>
                                        <TextBlock Text="PESEL:" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Pesel}" Margin="0,0,0,10" FontWeight="SemiBold"/>

                                        <TextBlock Text="Wynagrodzenie:" Foreground="Gray"/>
                                        <TextBlock Text="{Binding BaseSalary, StringFormat={}{0:C}}" Margin="0,0,0,10" FontWeight="SemiBold"/>

                                        <TextBlock Text="Data zatrudnienia:" Foreground="Gray"/>
                                        <TextBlock Text="{Binding HireDate, StringFormat=d}" Margin="0,0,0,10" FontWeight="SemiBold"/>

                                        <Separator Margin="0,5"/>
                                        <TextBlock Text="Adres:" Foreground="Gray"/>
                                        <TextBlock>
                                            <Run Text="{Binding Address.Street}"/> <Run Text="{Binding Address.HouseNumber}"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="{Binding Address.Zipcode}"/> <Run Text="{Binding Address.City}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Firmy">
                <Grid x:Name="FirmsView" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,10,0">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="Zarządzanie Firmami" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Odśwież" Command="{Binding LoadCommand}" Padding="10,5" Margin="0,0,5,0"/>
                                <Button Content="+ Dodaj Firmę" Command="{Binding AddCommand}" Padding="10,5" Background="#E2F0CB"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="Edytuj Firmę" Command="{Binding EditCommand}" Padding="10,5" Margin="0,0,5,0"/>
                            <Button Content="Usuń Firmę" Command="{Binding DeleteCommand}" Padding="10,5" Background="#FFE6E6"/>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding Firms}" 
                                  SelectedItem="{Binding SelectedFirm}"
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  BorderBrush="#CCC" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nazwa Firmy" Binding="{Binding Name}" Width="*" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="Siedziba" Binding="{Binding City}" Width="120"/>
                                <DataGridTextColumn Header="Pracowników" Binding="{Binding EmployeesCount}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" Padding="10" Background="#FAFAFA">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" FontSize="16" Margin="0,0,0,10">
                                <Run Text="Pracownicy zatrudnieni w: " Foreground="Gray"/>
                                <Run Text="{Binding SelectedFirm.Name, TargetNullValue='(Wybierz firmę)'}" FontWeight="Bold"/>
                            </TextBlock>

                            <ListBox ItemsSource="{Binding FirmEmployees}" BorderBrush="#EEE">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="30" Height="30" CornerRadius="15" Background="#DDD" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding FirstName, StringFormat={}{0:1}}" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="White"/>
                                            </Border>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontWeight="Bold">
                                                    <Run Text="{Binding FirstName}"/> <Run Text="{Binding LastName}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Position}" FontSize="11" Foreground="Gray"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Text="Brak pracowników w tej firmie." 
                                       FontStyle="Italic" Foreground="Gray" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FirmEmployees.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>