<Window x:Class="MG_Project.Desktop.Windows.AddFirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj Firmę" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="15" Width="300">
        <TextBlock Text="Nazwa Firmy:" FontWeight="Bold"/>
        <TextBox Text="{Binding Name}" Margin="0,0,0,10"/>

        <TextBlock Text="Miasto:" FontWeight="Bold"/>
        <TextBox Text="{Binding City}" Margin="0,0,0,10"/>

        <TextBlock Text="Ulica:" FontWeight="Bold"/>
        <TextBox Text="{Binding Street}" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Zapisz" Command="{Binding SaveCommand}" Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>